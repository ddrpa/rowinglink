{
  "schemaVersion": 1,
  "id": "rowinglink",
  "version": "${version}",
  "name": "RowingLink",
  "description": "Control Minecraft boats with a real rowing machine via FTMS protocol over UDP.",
  "authors": [
    "ddrpa"
  ],
  "contact": {
  },
  "license": "Apache-2.0",
  "icon": "assets/rowinglink/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "cc.ddrpa.minecraft.rowinglink.RowingLinkMod"
    ],
    "client": [
      "cc.ddrpa.minecraft.rowinglink.client.RowingLinkClient"
    ]
  },
  "mixins": [
    "rowinglink.mixins.json",
    {
      "config": "rowinglink.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
